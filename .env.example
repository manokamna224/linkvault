PORT=3000

# SQL Server instance
DB_SERVER=localhost\MSSQLSERVER01
DB_DATABASE=linkvault

# Windows Authentication (Integrated Security=True)
DB_TRUSTED_CONNECTION=true

# Encryption (Encrypt=True from SSMS connection string)
DB_ENCRYPT=true

# TrustServerCertificate — set false if SQL Server has a valid CA-signed cert,
# set true for local dev with self-signed certs
DB_TRUST_SERVER_CERT=true

# SQL Auth — only used when DB_TRUSTED_CONNECTION=false
# DB_USER=sa
# DB_PASSWORD=yourpassword

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
